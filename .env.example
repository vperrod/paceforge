# PaceForge — single-user, file-based. No database, no LLM API key.

# Garmin (required)
PACEFORGE_GARMIN_EMAIL=you@example.com
PACEFORGE_GARMIN_PASSWORD=         # only needed for the one-time `paceforge login`
PACEFORGE_GARMIN_TOKEN_DIR=        # cached session dir (default ~/.garminconnect)
GARMIN_TOKEN=                      # base64 token from `paceforge login`; set as a CI secret

# Strava (optional — activity description push)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REFRESH_TOKEN=

# Data location (default ./data)
PACEFORGE_DATA_DIR=
